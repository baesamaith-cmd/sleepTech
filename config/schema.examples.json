{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SleepTech Day Document",
  "description": "Canonical date-based JSON structure for morning and evening sleep logs",
  "type": "object",
  "required": ["date", "entries", "metadata"],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "entries": {
      "type": "object",
      "properties": {
        "morning": {
          "type": "object",
          "required": [
            "type",
            "date",
            "sleep_time",
            "wake_time",
            "sleep_quality",
            "awakenings",
            "submitted_at"
          ],
          "properties": {
            "type": { "const": "morning" },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "sleep_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
            "wake_time": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
            "sleep_quality": { "type": "integer", "minimum": 1, "maximum": 5 },
            "awakenings": { "type": "integer", "minimum": 0 },
            "memo": { "type": "string" },
            "submitted_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        },
        "evening": {
          "type": "object",
          "required": [
            "type",
            "date",
            "caffeine",
            "exercise",
            "nap",
            "submitted_at"
          ],
          "properties": {
            "type": { "const": "evening" },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "caffeine": { "type": "boolean" },
            "exercise": { "type": "boolean" },
            "nap": { "type": "boolean" },
            "stress_or_condition": { "type": "string" },
            "expected_bedtime": { "type": "string", "pattern": "^\\d{2}:\\d{2}$" },
            "memo": { "type": "string" },
            "submitted_at": { "type": "string", "format": "date-time" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "required": ["last_updated_at", "source"],
      "properties": {
        "last_updated_at": { "type": "string", "format": "date-time" },
        "source": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "date": "2026-04-09",
      "entries": {
        "morning": {
          "type": "morning",
          "date": "2026-04-09",
          "sleep_time": "22:30",
          "wake_time": "06:15",
          "sleep_quality": 4,
          "awakenings": 1,
          "memo": "Woke once around 3am.",
          "submitted_at": "2026-04-09T06:20:00Z"
        },
        "evening": {
          "type": "evening",
          "date": "2026-04-09",
          "caffeine": true,
          "exercise": false,
          "nap": false,
          "stress_or_condition": "Busy workday",
          "expected_bedtime": "23:00",
          "memo": "Trying to sleep earlier tonight.",
          "submitted_at": "2026-04-09T21:10:00Z"
        }
      },
      "metadata": {
        "last_updated_at": "2026-04-09T21:10:00Z",
        "source": "sleeptech-mvp"
      }
    }
  ]
}
